@page "/"
@page "/articles"
@inject NewsApiClient NewsApiClient
@inject NewsStateStore NewsStateStore

<PageTitle>Articles</PageTitle>

<div class="container py-4 py-lg-5">
    <div class="mb-4">
        <h1 class="display-6 mb-1 text-heading">Articles</h1>
        <p class="text-body-secondary mb-0">Select an article to read the full story.</p>
    </div>

    @if (_articles is null)
    {
        <div class="text-body-secondary text-heading">Loading articles...</div>
    }
    else if (_articles.Count == 0)
    {
        <div class="alert alert-light border mb-0">No articles are available.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var article in _articles)
            {
                <div class="col-12">
                    <a href="@($"/article/{article.Id}")"
                       class="card article-card border-0 shadow-sm rounded-4 text-decoration-none text-reset h-100">

                        <div class="card-body p-4">

                            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                <h2 class="h4 mb-0 fw-semibold text-heading">
                                    @article.Title
                                </h2>

                                <small class="text-nowrap text-highlight">
                                    @article.PublishDate.ToLocalTime().ToString("dd MMM yyyy")
                                </small>
                            </div>

                            <div class="small mb-3 text-highlight">
                                @article.Author
                            </div>

                            <p class="mb-0">
                                @GetPreview(article.Content)
                            </p>

                        </div>

                    </a>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<NewsArticle>? _articles;

    protected override async Task OnInitializedAsync()
    {
        _articles = await NewsApiClient.GetArticlesAsync();
        NewsStateStore.SetArticles(_articles);
    }

    private static string GetPreview(string content)
    {
        const int maxLength = 180;
        
        return content.Length <= maxLength
            ? content
            : $"{content[..maxLength].Trim()}...";
    }
}
